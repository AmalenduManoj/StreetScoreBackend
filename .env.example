# Copy into Render → Web Service → Environment (do not commit real values)

DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require
ALLOWED_ORIGINS=https://yourscore.onrender.com,http://localhost:5173
FRONTEND_RESET_PASSWORD_URL=https://yourscore.onrender.com/reset

# Render sets PORT automatically — do not override unless you know why
# HOST=0.0.0.0
# RUST_LOG=info

# Optional — forgot-password email
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
